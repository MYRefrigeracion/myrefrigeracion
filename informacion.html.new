<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Información Técnica | MY Refrigeración</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    /* Estilos generales */
    body {
      font-family: 'Arial', sans-serif;
      line-height: 1.6;
      margin: 0;
      padding: 0;
      color: #333;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }

    /* Estilos del encabezado */
    header {
      background-color: #fff;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      padding: 15px 0;
    }

    .header-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .logo {
      height: 80px;
      width: auto;
    }

    .slogan {
      font-size: 1.2rem;
      color: #1a73e8;
      font-style: italic;
      margin: 0;
    }

    /* Menú de navegación */
    nav {
      background-color: #1a73e8;
      padding: 10px 0;
    }

    .menu {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
    }

    .menu-item {
      color: white;
      text-decoration: none;
      padding: 10px 20px;
      display: block;
      transition: background-color 0.3s;
    }

    .menu-item:hover, .menu-item.active {
      background-color: #1557b0;
      border-radius: 4px;
    }

    /* Redes sociales */
    .social-links {
      display: flex;
      justify-content: center;
      padding: 15px 0;
      background-color: #f8f9fa;
    }

    .social-link {
      margin: 0 10px;
      transition: transform 0.3s;
    }

    .social-link:hover {
      transform: scale(1.1);
    }

    .social-icon {
      width: 32px;
      height: 32px;
    }

    /* Contenido principal */
    main {
      padding: 40px 0;
      background-color: #f8f9fa;
    }

    .info-container {
      background-color: white;
      border-radius: 8px;
      box-shadow: 0 2px 15px rgba(0,0,0,0.1);
      padding: 30px;
      max-width: 1000px;
      margin: 0 auto;
    }

    h1 {
      color: #1a73e8;
      text-align: center;
      margin-bottom: 30px;
      font-size: 2.2rem;
    }

    h2 {
      color: #1a73e8;
      margin-top: 30px;
      border-bottom: 2px solid #e0e0e0;
      padding-bottom: 10px;
    }

    .kit-section {
      margin-bottom: 30px;
    }

    .materials-list {
      list-style-type: none;
      padding: 0;
    }

    .materials-list li {
      padding: 10px 0;
      padding-left: 30px;
      position: relative;
      border-bottom: 1px solid #eee;
    }

    .materials-list li:before {
      content: "•";
      color: #1a73e8;
      font-weight: bold;
      font-size: 1.5rem;
      position: absolute;
      left: 10px;
      top: 5px;
    }

    .important-note {
      background-color: #e3f2fd;
      border-left: 4px solid #1a73e8;
      padding: 15px;
      margin: 20px 0;
      border-radius: 0 4px 4px 0;
    }

    .important-note h3 {
      margin-top: 0;
      color: #0d47a1;
    }

    /* Pie de página */
    footer {
      background-color: #1a73e8;
      color: white;
      padding: 40px 0 20px;
    }

    .footer-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 30px;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .footer-column h3 {
      color: white;
      margin-top: 0;
      font-size: 1.2rem;
    }

    .footer-links {
      list-style: none;
      padding: 0;
    }

    .footer-links li {
      margin-bottom: 10px;
    }

    .footer-links a {
      color: #e0e0e0;
      text-decoration: none;
      transition: color 0.3s;
    }

    .footer-links a:hover {
      color: white;
      text-decoration: underline;
    }

    .copyright {
      text-align: center;
      margin-top: 30px;
      padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.1);
      font-size: 0.9rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .header-container {
        flex-direction: column;
        text-align: center;
      }

      .logo {
        margin-bottom: 15px;
      }

      .menu {
        flex-direction: column;
        align-items: center;
      }

      .menu-item {
        padding: 8px 15px;
      }

      .info-container {
        padding: 20px 15px;
      }

      h1 {
        font-size: 1.8rem;
      }
    }
  </style>
</head>
<body>
